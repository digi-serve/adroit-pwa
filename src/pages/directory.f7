          <img @error=${imageLoadError} class="imageProfile" src="${Api.absoluteUrl('/file/')}${user.value.Photo||'69ac639f-1272-4f4e-bcc5-c36f2863ef31'}" style="margin-top: 15px; border: 5px solid white; width: 180px; height: 180px; object-fit: contain; background-color: #CCC; border-radius: 100%" />
        ` : $h`
