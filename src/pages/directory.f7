<script>
  import Api from "/js/api.js";
  import store from "/js/store.js";
  import fetchJson from "/js/fetch.js";
  import introJs from "intro.js";
  import 'intro.js/introjs.css';
  import i18next from 'i18next';
  import english from '/js/locales/english.json';
  import thai from '/js/locales/thai.json';

  function phiNongKhun(thierBirthday, yourBirthday) {
    const yourBDay = new Date(yourBirthday);
    const theirBDay = new Date(thierBirthday);
    const oneYearEarlier = new Date(yourBirthday);
    oneYearEarlier.setFullYear(oneYearEarlier.getFullYear() - 1);
    const oneYearLater = new Date(yourBirthday);
    oneYearLater.setFullYear(oneYearLater.getFullYear() + 1);
    let say = "khun";
    if (oneYearEarlier > theirBDay) {
      say = "pi";
    } else if (oneYearEarlier < theirBDay && oneYearLater > theirBDay) {
      say = "khun";
    } else if (oneYearLater < theirBDay) {
      say = "nong";
    }
    return say;
  }

  function isBirthdayWithinOneWeek(birthDateString) {
    const now = new Date();
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const birthDate = new Date(birthDateString);

    // Set the birthdate to the current year for comparison
    let nextBirthday = new Date(today.getFullYear(), birthDate.getMonth(), birthDate.getDate());

    // If the birthday already passed this year, check next year's date
    if (nextBirthday < today) {
      nextBirthday.setFullYear(today.getFullYear() + 1);
    }

    // Calculate the difference in milliseconds and convert to days
    const diffInMs = nextBirthday - today;
    const diffInDays = diffInMs / (1000 * 60 * 60 * 24);

    return diffInDays >= 0 && diffInDays <= 7;
  }

  export default (props, { $, $f7, $on, $update, $store }) => {
    const fcfStaffVolunteersLoading = $store.getters.fcfStaffVolunteersLoading;
    let isDesktop = app.f7.device.desktop;
    let popup;
    let popoverEmail;
    let popoverPhone;
    let pickerDependent;
    let toastIcon;

    let directorySkeleton = [1,2,3,4,5,6,7,8];
    const fcfStaffVolunteers = $store.getters.fcfStaffVolunteers;
    // debugger;
    const user = $store.getters.user;
    const locale = $store.getters.locale;
    const allProjects = $store.getters.allProjects;
    // store.dispatch("getSiteUserId");
    const username = $store.getters.username;
    const gotUser = $store.getters.gotUser;
    // const gotUser = {value: false};
    const isSwitcheroo = $store.getters.switcheroo;
    const hasSwitcheroo = $store.getters.hasSwitcheroo;

    $store.dispatch("getUser");
    $store.dispatch('getAllProjects');

    i18next.init({
      lng: locale.value,
      resources: {
        en: english,
        th: thai,
      }
    });

    $on('pageInit', () => {
      $store.dispatch("fetchFCFStaffVolunteers");
      // console.log(user);

      var contactTypes = {
        Phone: ['Mobile', 'Home', 'Work', 'School', 'Main', 'Other'],
        Email: ['Home', 'Work', 'School', 'Other'],
        Social: ['LINE', 'Facebook', 'Instagram', 'Other']
      };
      var contactTypesTranslated = {
        Phone: [i18next.t('Mobile'), i18next.t('Home'), i18next.t('Work'), i18next.t('School'), i18next.t('Main'), i18next.t('Other')],
        Email: [i18next.t('Home'), i18next.t('Work'), i18next.t('School'), i18next.t('Other')],
        Social: [i18next.t('LINE'), i18next.t('Facebook'), i18next.t('Instagram'), i18next.t('Other')]
      };

      pickerDependent = $f7.picker.create({
        inputEl: '#typePicker',
        rotateEffect: true,
        formatValue: function (values) {
          return i18next.t(values[0]) + ": " + i18next.t(values[1]);
        },
        cols: [
          {
            textAlign: 'left',
            values: ['Phone', 'Email', 'Social'],
            displayValues: [i18next.t('Phone'), i18next.t('Email'), i18next.t('Social')],
            onChange: function (picker, type) {
              if (picker.cols[1].replaceValues) {
                picker.cols[1].replaceValues(contactTypesTranslated[type]);
              }
            }
          },
          {
            values: contactTypes.Phone,
            displayValues: contactTypesTranslated.Phone
          },
        ]
      });

    })

    $on('pageBeforeRemove', () => {
      pickerDependent.destroy();
    });

    $on('pageReinit', () => {
    });

    $on('pageAfterIn', (e, page) => {
      characterCounter();
    });

    user.onUpdated(() => {
      // characterCounter();
    })

    const reloadDirectory = (e, done) => {
      $store.dispatch("fetchFCFStaffVolunteers", done);
    }

    const trans = (object) => {
      return object[locale.value];
    }

    const profilePhoto = () => {
      $("#profilePhoto").click();
    }

    const openPicker = () => {
      pickerDependent.open();
    }

    const showStaff = () => {
      document.querySelectorAll('.type-staff').forEach(el => {
        if (el.classList.contains("hidePerson")) {
          el.classList.remove('hidePerson');
          el.classList.add('showPerson');
        } else {
          el.classList.add('hidePerson');
          el.classList.remove('showPerson');
        }
      });      
    }

    const showVolunteer = () => {
      document.querySelectorAll('.type-volunteer').forEach(el => {
        if (el.classList.contains("hidePerson")) {
          el.classList.remove('hidePerson');
          el.classList.add('showPerson');
        } else {
          el.classList.add('hidePerson');
          el.classList.remove('showPerson');
        }
      });
    }

    const showDirector = () => {
      document.querySelectorAll('.is-director').forEach(el => {
        if (el.classList.contains("hidePerson")) {
          el.classList.remove('hidePerson');
          el.classList.add('showPerson');
        } else {
          el.classList.add('hidePerson');
          el.classList.remove('showPerson');
        }
      });
    }

    const showUpcomingBirthdays = () => {
      var bdayToggle = app.f7.toggle.get('.bdaytoggle');
      var staffToggle = app.f7.toggle.get('.stafftoggle');
      var volunteertoggle = app.f7.toggle.get('.volunteertoggle');
      var directorToggle = app.f7.toggle.get('.directortoggle');
      if (!staffToggle.checked) {
        staffToggle.toggle();
      }
      if (!volunteertoggle.checked) {
        volunteertoggle.toggle();
      }
      if (!directorToggle.checked) {
        directorToggle.toggle();
      }
      if (bdayToggle.checked) {
        document.querySelectorAll('.person').forEach(el => {
          if (el.classList.contains("bDaySoon")) {
            el.classList.remove('hidePerson');
            el.classList.add('showPerson');
          } else {
            el.classList.add('hidePerson');
            el.classList.remove('showPerson');
          }
        });
      } else {
        document.querySelectorAll('.person').forEach(el => {
          el.classList.remove('hidePerson');
          el.classList.add('showPerson');
        });        
      }
    }
   
    const filterProject = (e) => {
      var formData = $f7.form.convertToData('#filterProject');
      if (formData.project == "all") {
        document.querySelectorAll('.person').forEach(el => {
          el.classList.remove('hideProject');
          el.classList.add('showProject');
        });
      } else {
        document.querySelectorAll('.person').forEach(el => {
          if (el.classList.contains(formData.project.toLowerCase())) {
            el.classList.remove('hideProject');
            el.classList.add('showProject');
          } else {
            el.classList.add('hideProject');
            el.classList.remove('showProject');
          }
        });        
      }
    }

    const imageLoadError = (e) => {
      if (!e.target.dataset.retry || e.target.dataset.retry < 5) {
        setTimeout(() => {
          e.target.src = e.target.src;

          e.target.dataset.retry = (!e.target.dataset.retry) ? 1 : (parseInt(e.target.dataset.retry) + 1);
          // console.log(`trying to load image: ${e.target.dataset.retry}`)
        }, 2000);
      } else {
        // e.target.src = "/pwa/www/assets/images/1024.png";
        // e.target.style.objectFit = "contain";
      }
    }

    const createPopup = (listing) => {
      // Create popup
      // console.log(listing);

      let isOlder = phiNongKhun(listing["Birth Date"], user.value["Birth Date"]);
      let older = "";
      if (isOlder == "pi") {
        older = "<i class='icon material-icons'>favorite_border</i>";
      }

      let name = [];
      
      
      if ((listing[trans({'en':'Preferred Name','th':'Preferred Name Thai'})] != listing[trans({'en':'First Name','th':'First Name Thai'})] && listing[trans({'en':'Preferred Name','th':'Preferred Name Thai'})] != "")) {
        name.push(listing[trans({'en':'First Name','th':'First Name Thai'})]);
        name.push(`(${i18next.t(isOlder)}${listing[trans({'en':'Preferred Name','th':'Preferred Name Thai'})]})`); 
      } else {
        name.push(`${i18next.t(isOlder)}${listing[trans({'en':'First Name','th':'First Name Thai'})]}`)        
      }
      name.push(listing[trans({'en':'Last Name','th':'Last Name Thai'})]);
      
      let pro = "";
      listing.Project__relation.forEach((project) => {
        pro += `<div class="chip margin-right-4">`;
        if (project.isDirector) {
          pro += `<div class="chip-media bg-color-deeppurple">
            <i class="icon material-icons">local_police</i>
          </div>`;
        }
        pro += `<div class="chip-label">${project[trans({'en':'PP','th':'Project Name TH'})]}</div> 
        </div>`; 
      });
      let background = (listing['Person Type'] == "Staff" ? "deeporange" : "blue");
      if (listing.isDirector) {
        background = "deeppurple";
      }
      let phone = "";
      let social = "";
      let email = "";
      let hasPhone = "disabled";
      let hasSocial = "disabled";
      let hasEmail = "disabled";
      listing.Person305__relation.forEach((item) => {
        if (item.Public == 1) {
          if (item.Type == "Phone") {
            if (phone.length) {
              phone += "<hr/>";
            }
            phone += '<div>' + (item.Description ? item.Description : "Phone number") + '</div>'; 
            phone += `<div><a class="lighter text-color-white external" href="tel:${item.Contact}">${item.Contact}</a></div>`;
          } else if (item.Type == "Social") {
            if (social.length) {
              social += "<hr/>";
            }
            social += '<div>' + (item.Description ? item.Description : "Social media") + '</div>'; 
            if (item.Description == "Facebook") {
              social += `<div class="lighter"><a class="external color-white" href="https://www.facebook.com/${item.Contact}"><i class="icon material-icons small">link</i> ${item.Contact}</a></div>`;
            } else if (item.Description == "Instagram") {
              social += `<div class="lighter"><a class="external color-white" href="https://www.instagram.com/${item.Contact}"><i class="icon material-icons small">link</i> ${item.Contact}</a></div>`;
            } else {
              social += `<div class="lighter">${item.Contact}</div>`;
            }
          } else if (item.Type == "Email") {
            if (email.length) {
              email += "<hr/>";
            }
            email += '<div>' + (item.Description ? item.Description : "Email address") + '</div>'; 
            email += `<div><a class="lighter text-color-white external" href="mailto:${item.Contact}">${item.Contact}</a></div>`;
          }          
        }
      });
      if (phone) {
        document.getElementById("phoneContent").innerHTML = phone;
        hasPhone = "";
      }
      if (social) {
        document.getElementById("socialContent").innerHTML = social;
        hasSocial = "";
      }
      if (email) {
        document.getElementById("emailContent").innerHTML = email;
        hasEmail = "";
      }

      if (popup) {
        popup.destroy();
      }
      popup = $f7.popup.create({
        swipeToClose: true,
        push: true,
        content: /*html*/`
          <div class="popup directory-block">
            <div class="page light bg-color-${background}">
              <div class="navbar">
                <div class="navbar-bg"></div>
                <div class="navbar-inner">
                  <div class="title"></div>
                  <div class="right"><a  class="link popup-close"><i class="icon icon-close"></i></a></div>
                </div>
              </div>
              <div class="page-content">
                <img id="listingPhotoMove" style="border: 5px solid white; border-radius: 100%; object-fit: cover; margin: 0px auto 20px auto; width: 250px; height: 250px; display: block;" src="${Api.absoluteUrl('/file/')}${listing.Photo||'69ac639f-1272-4f4e-bcc5-c36f2863ef31'}" width="250" height="250" />
                <h1 class="text-align-center no-margin" style="padding: 0 20px;">${name.join(" ")}</h1>
                <div class="navbar no-margin no-box-shadow">
                  <div class="navbar-inner" style="justify-content: center;">
                    <div class="left">
                      <a id="phoneButton" class="link icon-only popover-open ${hasPhone}" data-popover=".popover-phone">
                        <i class="icon material-icons">phone</i>
                      </a>
                    </div>
                    <div class="right" style="margin: 0;">  
                      <a id="socialButton" class="link icon-only popover-open ${hasSocial}" data-popover=".popover-social">
                        <i class="icon material-icons">chat</i>
                      </a>
                    </div>
                    <div class="right">  
                      <a id="emailButton" class="link icon-only popover-open ${hasEmail}" data-popover=".popover-email">
                        <i class="icon material-icons">mail</i>
                      </a>
                    </div>
                  </div>
                </div>
                <div class="block block-strong inset no-margin-top">
                  <div>${i18next.t("project")}</div> 
                  <div>${pro}</div>
                  <hr/>
                  <div>${i18next.t("jobTitle")}</div> 
                  <div class="lighter">${listing["Job Title"]}<br/></div>
                  <hr/>
                  <div>${i18next.t("type")}</div> 
                  <div>
                    <div class="chip margin-right-4 color-${listing["Person Type"].toLowerCase()}">
                      <div class="chip-label">${i18next.t(listing["Person Type"])}</div>
                    </div>
                  </div>  
                  <hr/>
                  <div>${i18next.t("birthday")}</div> 
                  <div class="lighter">${older} ${new Date(listing["Birth Date"]).toLocaleDateString(locale.value, { month: 'long', day: 'numeric' })}</div>
                  <hr/>
                  <div>${i18next.t("bio")}</div> 
                  <div class="lighter">${listing["Bio"]}</div>                                    
                </div>
              </div>
            </div>
          </div>
        `
      });
      // Open it
      popup.open();
    }

    const characterCounter = (e) => {
      let textArea = $('.charCount')[0];
      $f7.input.validate(textArea);
      let length = textArea.value.length;
      if (length <= 240) {
        $('.charCountHolder').html(`${length}/240 ${i18next.t('characters')}`);
      } else {
        let trimmed = textArea.value.substr(0,240);
        textArea.value = trimmed;
        $('.charCountHolder').html(`240/240 ${i18next.t('characters')}`);
      }
    }

    const removeContact = (id) => {
      $f7.dialog.confirm('Remove?', () => {
        let el = document.querySelector('#contact-'+id);
        el.remove();
        let vals = {};
        vals.id = id;
        const urlContact = Api.urls.updateContact(id);
        const optionsContact = {
          method: 'DELETE'
        };

        // this.status = ActivityStatus.saving;
        fetchJson(urlContact, optionsContact)
          .then(response => {
            // console.log(response);
          })
          .catch(async error => {
            // console.log(error);
          });
      });
    }

    const addContact = () => {
      let valid = app.f7.input.validateInputs('#newContact');
      if (!valid) {
        return false;
      }
      var formData = $f7.form.convertToData('#newContact');
      let vals = pickerDependent.getValue();
      if (vals && vals.length == 2) {
        formData.Type = vals[0];
        formData.Description = vals[1];
      } else {
        return false;
      }
      formData.Person = user.value.uuid;
      const urlContact = Api.urls.addContact();
      const optionsContact = {
        method: 'POST',
        params: formData,
      };
      if (formData.Public.length) {
        formData.Public = 1;
      } else {
        formData.Public = null;
      }
      // console.log("optionsContact: ", optionsContact);
      // this.status = ActivityStatus.saving;
      fetchJson(urlContact, optionsContact)
        .then(response => {
          // console.log(response);
          $store.dispatch("getUser");
          document.getElementById("addContactValue").value = "";
          if (!toastIcon) {
            toastIcon = $f7.toast.create({
              icon: '<i class="f7-icons">star_fill</i>',
              text: 'Saved',
              position: 'center',
              closeTimeout: 2000,
            });
          }
          // Open it
          toastIcon.open();
        })
        .catch(async error => {
          // console.log(error);
        });
    }

    const saveProfile = () => {
      var formData = $f7.form.convertToData('#myProfile');

      var contactForms = $('.contactForms');
      var contactVals = [];
      contactForms.forEach((form) => {
        let tempVals = $f7.form.convertToData(form);
        tempVals.Person = user.value.uuid
        if (tempVals.Public.length) {
          tempVals.Public = 1;
        } else {
          tempVals.Public = null;
        }
        contactVals.push(tempVals);

        const urlContact = Api.urls.updateContact(tempVals.id);
        // console.log("body: ", tempVals);
        const optionsContact = {
          method: 'PUT',
          params: tempVals,
        };

        // this.status = ActivityStatus.saving;
        fetchJson(urlContact, optionsContact)
          .then(response => {
            // console.log(response);
          })
          .catch(async error => {
            // console.log(error);
          });

      })

      const url = Api.urls.updateProfilePhoto(user.value.uuid);
      let body = {};
      body.id = user.value.uuid;
      body['Preferred Name'] = formData.nicknameEnglish;
      body['Preferred Name Thai'] = formData.nicknameThai;
      body['Job Title'] = formData.jobTitle;
      body['Bio'] = formData.bio;
      // console.log("body: ", body);
      const options = {
        method: 'PUT',
        params: body,
      };

      // this.status = ActivityStatus.saving;
      fetchJson(url, options)
        .then(response => {
          // console.log(response);
          $store.dispatch("fetchFCFStaffVolunteers");
          // Create toast
          if (!toastIcon) {
            toastIcon = $f7.toast.create({
              icon: '<i class="f7-icons">star_fill</i>',
              text: 'Saved',
              position: 'center',
              closeTimeout: 2000,
            });
          }
          // Open it
          toastIcon.open();
        })
        .catch(async error => {
          // console.log(error);
        });

    }

    return $render;
  }
</script>